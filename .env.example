# ══════════════════════════════════════
# SocialPulse Environment Variables
# ══════════════════════════════════════

# GenLayer Intelligent Contract address (after deploying contracts/social_intelligence.py)
# Deploy with: PRIVATE_KEY=0x... npx tsx contracts/deploy.ts
VITE_CONTRACT_ADDRESS=

# X (Twitter) API Proxy URL (optional — enables live X data)
# Run the proxy: cd server && npm install && npm start
VITE_X_API_PROXY_URL=
