# ══════════════════════════════════════
# X (Twitter) API Configuration
# ══════════════════════════════════════

# Your X API Bearer Token
# Get it from: https://developer.x.com/en/portal/dashboard
X_BEARER_TOKEN=your_bearer_token_here

# Server port
PORT=3001

# CORS origin (your frontend URL)
CORS_ORIGIN=http://localhost:5173

# ── Optional: Use a third-party X API instead ──
# Cheaper alternatives to the official X API:
#
# TwitterAPI.io ($0.00015/read):
#   X_API_BASE_URL=https://api.twitterapi.io/twitter
#   X_BEARER_TOKEN=your_twitterapi_io_key
#
# GetXAPI ($0.05/1000 tweets):
#   X_API_BASE_URL=https://api.getxapi.com/v2
#   X_BEARER_TOKEN=your_getxapi_key

X_API_BASE_URL=https://api.x.com/2
